---
interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<div class="deb-result" id="deb-result" style="display: none">
  <div class="deb-result-card">
    <h2 class="deb-result-title">{t.resultTitle}</h2>

    <div class="deb-badge-container">
      <div id="deb-badge-display" class="deb-badge-display"></div>
    </div>

    <div class="deb-result-info">
      <p class="deb-result-desc" id="deb-result-desc"></p>
      <div class="deb-warning-box">
        <svg
          width="20"
          height="20"
          fill="none"
          viewBox="0 0 24 24"
          stroke="#f59e0b"
          stroke-width="2"
          ><path
            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
          ></path></svg
        >
        <p class="deb-result-warn">{t.warningText}</p>
      </div>
    </div>

    <button type="button" class="deb-reset-btn" id="deb-reset">
      <svg
        width="18"
        height="18"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
        ><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8m0 0V3m0 5h5"
        ></path></svg
      >
      {t.resetBtn}
    </button>
  </div>
</div>

<style>
  .deb-result {
    display: none;
    flex-direction: column;
    animation: deb-slide-up 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .deb-result-card {
    background: var(--deb-result-bg);
    border-radius: 1.5rem;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border: 1px solid var(--deb-card-border);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .deb-result-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--deb-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 2rem;
  }

  .deb-badge-container {
    margin-bottom: 2rem;
    filter: drop-shadow(0 15px 30px rgba(0, 0, 0, 0.1));
  }

  .deb-result-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 640px;
    width: 100%;
  }

  .deb-result-desc {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.6;
    color: var(--deb-text-main);
  }

  .deb-warning-box {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: rgba(245, 158, 11, 0.08);
    border-radius: 1rem;
    border: 1px solid rgba(245, 158, 11, 0.2);
    text-align: left;
  }

  .deb-result-warn {
    font-size: 0.8125rem;
    color: #b45309;
    font-weight: 500;
    line-height: 1.5;
  }

  :global(.theme-dark) .deb-result-warn {
    color: #fbbf24;
  }

  .deb-reset-btn {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 2rem;
    background: var(--deb-option-bg);
    border: 1px solid var(--deb-option-border);
    border-radius: 100px;
    color: var(--deb-text-main);
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .deb-reset-btn:hover {
    background: var(--deb-option-hover);
    transform: scale(1.05);
  }

  @keyframes deb-slide-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
